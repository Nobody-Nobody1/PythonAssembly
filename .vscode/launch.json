{
   "version": "0.2.0",
   "configurations": [
    
    
       {
           "name": "Python: VmExecuter",
           "type": "debugpy",
           "request": "launch",
           "program": "${workspaceFolder}/src/vmexecuter.py",
           "console": "integratedTerminal"
       },
         {
              "name": "Python: Web",
              "type": "debugpy",
              "request": "launch",
              "program": "${workspaceFolder}/web/Web.py",
              "console": "integratedTerminal"
         },
         {
              "name": "Python: Current File",
              "type": "debugpy",
              "request": "launch",
              "program": "${file}",
              "console": "integratedTerminal"
         },
         {
              "name": "Python: PythonAssembly IDE",
              "type": "debugpy",
              "request": "launch",
              "program": "${workspaceFolder}/vm_gui.py",
              "console": "integratedTerminal"
         }
   ]
}